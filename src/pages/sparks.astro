---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import sparks from '../data/sparks.json';

const SITE_TITLE = "灵感流 | 大响的铲子铺";
const SITE_DESCRIPTION = "随手记下的念头、洞察和时刻，未经打磨，原味呈现。";

const tagColors: Record<string, string> = {
  "用户洞察": "tag-insight",
  "产品灵感": "tag-product",
  "商业模式": "tag-biz",
  "成长规律": "tag-growth",
};
---

<!doctype html>
<html lang="zh">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: 2em auto;
        padding: 0 1em;
      }
      .page-header {
        margin-bottom: 2.5em;
        border-bottom: 1px solid rgb(var(--gray-light));
        padding-bottom: 1.5em;
      }
      .page-header h1 {
        font-size: 1.8em;
        margin-bottom: 0.3em;
      }
      .page-header p {
        color: rgb(var(--gray));
        font-size: 0.95em;
      }
      .spark-list {
        display: flex;
        flex-direction: column;
        gap: 1.5em;
      }
      .spark {
        display: grid;
        grid-template-columns: 7em 1fr;
        gap: 0 1.2em;
        align-items: start;
      }
      .spark-date {
        color: rgb(var(--gray));
        font-size: 0.85em;
        padding-top: 0.25em;
        white-space: nowrap;
      }
      .spark-body {
        border-left: 2px solid rgb(var(--gray-light));
        padding-left: 1em;
      }
      .spark-body p {
        margin: 0 0 0.5em 0;
        line-height: 1.7;
        color: rgb(var(--gray-dark));
      }
      .tags {
        display: flex;
        gap: 0.4em;
        flex-wrap: wrap;
      }
      .tag {
        font-size: 0.75em;
        padding: 0.15em 0.55em;
        border-radius: 999px;
        font-weight: 500;
      }
      .tag-insight  { background: #e8f4fd; color: #1a6fa8; }
      .tag-product  { background: #fef3e2; color: #a05c00; }
      .tag-biz      { background: #e8f8f0; color: #1a7a45; }
      .tag-growth   { background: #f3e8fd; color: #6a1a9a; }
      @media (max-width: 540px) {
        .spark {
          grid-template-columns: 1fr;
        }
        .spark-date {
          font-size: 0.8em;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1>灵感流</h1>
        <p>随手记下的念头、洞察和时刻。未经打磨，原味呈现。</p>
      </div>
      <div class="spark-list">
        {sparks.map((spark) => (
          <div class="spark">
            <span class="spark-date">{spark.date}</span>
            <div class="spark-body">
              <p>{spark.text}</p>
              {spark.tags.length > 0 && (
                <div class="tags">
                  {spark.tags.map((tag) => (
                    <span class={`tag ${tagColors[tag] ?? ''}`}>{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
